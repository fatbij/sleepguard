<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- 1. Full-screen Lottie — behind everything -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieAnimation"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        app:lottie_fileName="day_night_cycle.json"
        app:lottie_autoPlay="false"
        app:lottie_loop="false" />

    <!-- 2. Bottom gradient scrim for button readability -->
    <View
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_scrim" />

    <!-- 3. Gear button — top start -->
    <ImageButton
        android:id="@+id/btnGear"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|start"
        android:layout_margin="20dp"
        android:background="@drawable/bg_gear_button"
        android:src="@drawable/ic_settings"
        android:padding="10dp"
        android:contentDescription="Settings" />

    <!-- 4. X close — top end -->
    <TextView
        android:id="@+id/tvClose"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_margin="20dp"
        android:text="✕"
        android:textSize="20sp"
        android:textColor="#88FFFFFF"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true" />

    <!-- 5. Bottom UI overlay (buttons + wake text) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="56dp"
        android:paddingTop="16dp">

        <!-- Wake-mode greeting (gone during sleep) -->
        <TextView
            android:id="@+id/tvMorningGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Good morning"
            android:textSize="26sp"
            android:textColor="#FFF8F0"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:layout_marginBottom="6dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvMorningMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Have a great and productive day"
            android:textSize="14sp"
            android:textColor="#CCFFF8F0"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="32dp"
            android:visibility="gone" />

        <!-- I'm awake — primary action, top -->
        <TextView
            android:id="@+id/tvBeginGently"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="I'm awake"
            android:textSize="15sp"
            android:textColor="#CCFFFFFF"
            android:background="@drawable/pill_soft"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="14dp" />

        <!-- Unlock phone — secondary ghost text below -->
        <TextView
            android:id="@+id/tvUnlock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unlock phone"
            android:textSize="13sp"
            android:textColor="#55FFFFFF"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.05"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- 6. Settings overlay — full screen -->
    <FrameLayout
        android:id="@+id/settingsPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#EE0A1228"
        android:visibility="gone">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sleep Settings"
                    android:textSize="20sp"
                    android:textColor="#DDEEFF"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginBottom="32dp" />

                <!-- Bedtime -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="BEDTIME" android:textSize="11sp" android:textColor="#66AACCEE"
                    android:letterSpacing="0.15" android:layout_marginBottom="8dp" />
                <TextView android:id="@+id/tvSettingsSleep"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="22:30" android:textSize="36sp" android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-thin" android:gravity="center"
                    android:background="@drawable/bg_time_box" android:paddingTop="12dp"
                    android:paddingBottom="12dp" android:clickable="true" android:focusable="true"
                    android:layout_marginBottom="24dp" />

                <!-- Wake time -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="WAKE TIME" android:textSize="11sp" android:textColor="#66AACCEE"
                    android:letterSpacing="0.15" android:layout_marginBottom="8dp" />
                <TextView android:id="@+id/tvSettingsWake"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="07:00" android:textSize="36sp" android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-thin" android:gravity="center"
                    android:background="@drawable/bg_time_box" android:paddingTop="12dp"
                    android:paddingBottom="12dp" android:clickable="true" android:focusable="true"
                    android:layout_marginBottom="32dp" />

                <!-- Night waking plan -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="NIGHT WAKING PLAN" android:textSize="11sp"
                    android:textColor="#66AACCEE" android:letterSpacing="0.15"
                    android:layout_marginBottom="16dp" />

                <!-- Breathing -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/bg_time_box" android:padding="16dp"
                    android:layout_marginBottom="10dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Breathing" android:textSize="15sp" android:textColor="#DDEEFF"
                            android:fontFamily="sans-serif-light" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Focus on slow breaths" android:textSize="12sp"
                            android:textColor="#44AACCEE" />
                    </LinearLayout>
                    <TextView android:id="@+id/tvSettingsBreathing"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="5 mins" android:textSize="18sp" android:textColor="#FFFFFF"
                        android:fontFamily="sans-serif-thin" android:clickable="true"
                        android:focusable="true" android:background="@drawable/pill_soft"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:paddingTop="6dp" android:paddingBottom="6dp" />
                </LinearLayout>

                <!-- Quiet rest -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/bg_time_box" android:padding="16dp"
                    android:layout_marginBottom="10dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Quiet rest" android:textSize="15sp" android:textColor="#DDEEFF"
                            android:fontFamily="sans-serif-light" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Stay still, let sleep return" android:textSize="12sp"
                            android:textColor="#44AACCEE" />
                    </LinearLayout>
                    <TextView android:id="@+id/tvSettingsResting"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="10 mins" android:textSize="18sp" android:textColor="#FFFFFF"
                        android:fontFamily="sans-serif-thin" android:clickable="true"
                        android:focusable="true" android:background="@drawable/pill_soft"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:paddingTop="6dp" android:paddingBottom="6dp" />
                </LinearLayout>

                <!-- Leave bed -->

                <!-- Escalation -->

                <TextView
                    android:id="@+id/tvSettingsDone"
                    android:layout_width="160dp"
                    android:layout_height="wrap_content"
                    android:text="Done"
                    android:textSize="15sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/pill_soft"
                    android:paddingTop="13dp"
                    android:paddingBottom="13dp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>
        </ScrollView>
    </FrameLayout>

</FrameLayout>
