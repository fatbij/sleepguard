<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/wakeRootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A">

    <!-- 1. Full-screen Lottie animation — no clipping -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieIcon"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:lottie_rawRes="@raw/weather_animation"
        app:lottie_autoPlay="false"
        app:lottie_loop="true"
        app:lottie_renderMode="hardware" />

    <!-- 2. Top gradient scrim — softens top edge -->
    <View
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_gravity="top"
        android:background="@drawable/bg_top_scrim" />

    <!-- 3. Bottom gradient scrim — stronger for readability -->
    <View
        android:layout_width="match_parent"
        android:layout_height="360dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_scrim" />

    <!-- 4. Phase title + dots + timer — sits above scrim -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_gravity="bottom"
        android:layout_marginBottom="150dp">

        <TextView
            android:id="@+id/tvPhaseTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Breathe slowly"
            android:textSize="22sp"
            android:textColor="#DDEEFF"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <!-- 3 dots only — dot4 removed -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <View
                android:id="@+id/dot1"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_active"
                android:layout_marginEnd="8dp" />

            <View
                android:id="@+id/dot2"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_inactive"
                android:layout_marginEnd="8dp" />

            <View
                android:id="@+id/dot3"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_inactive" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvElapsed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="#55AACCEE"
            android:fontFamily="sans-serif-thin"
            android:letterSpacing="0.05" />

    </LinearLayout>

    <!-- 5. Action buttons at bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_gravity="bottom"
        android:layout_marginBottom="56dp">

        <TextView
            android:id="@+id/tvSleepyAgain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="I'm sleepy again"
            android:textSize="15sp"
            android:textColor="#DDEEFF"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.08"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvLeaveBed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Leave the bed"
            android:textSize="15sp"
            android:textColor="#DDEEFF"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.08"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:visibility="gone" />

    </LinearLayout>

</FrameLayout>
