<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SleepGuard" parent="Theme.AppCompat.DayNight.DarkActionBar">
        <item name="colorPrimary">#2E6FD9</item>
        <item name="colorPrimaryDark">#0D1B3E</item>
        <item name="colorAccent">#7EB8FF</item>
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
    </style>

    <style name="Theme.LockScreen" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
