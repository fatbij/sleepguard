<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_sleep">

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

        <!-- Icon -->
        <TextView
            android:id="@+id/tvIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌙"
            android:textSize="80sp"
            android:layout_marginBottom="20dp" />

        <!-- Status -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sleep Window"
            android:textSize="22sp"
            android:textColor="#DDEEFF"
            android:fontFamily="sans-serif-light"
            android:layout_marginBottom="8dp" />

        <!-- Soft guidance text -->
        <TextView
            android:id="@+id/tvGuidance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rest quietly"
            android:textSize="14sp"
            android:textColor="#55AACCEE"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.03"
            android:layout_marginBottom="56dp" />

        <!-- Morning message - wake window only -->
        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Have a beautiful,\nproductive day"
            android:textSize="22sp"
            android:textColor="#FFF8F0"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="56dp"
            android:visibility="gone" />

        <!-- Unlock button -->
        <TextView
            android:id="@+id/tvUnlock"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:text="Tap to unlock"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/pill_soft"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="12dp" />

        <!-- Begin gently - soft, dim, unobtrusive -->
        <TextView
            android:id="@+id/tvBeginGently"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Begin gently"
            android:textSize="13sp"
            android:textColor="#44AACCEE"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.05"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="8dp" />

        <!-- Stop SleepGuard -->
        <TextView
            android:id="@+id/tvStop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stop SleepGuard"
            android:textSize="12sp"
            android:textColor="#33FFFFFF"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:clickable="true"
            android:focusable="true" />

        <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

    </LinearLayout>

    <!-- Gear button -->
    <ImageButton
        android:id="@+id/btnGear"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_margin="20dp"
        android:background="@drawable/bg_gear_button"
        android:src="@drawable/ic_settings"
        android:padding="10dp"
        android:contentDescription="Settings" />

    <!-- Settings overlay panel -->
    <LinearLayout
        android:id="@+id/settingsPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:background="#EE0A1228"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sleep Settings"
            android:textSize="20sp"
            android:textColor="#DDEEFF"
            android:fontFamily="sans-serif-light"
            android:layout_marginBottom="32dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BEDTIME"
            android:textSize="11sp"
            android:textColor="#66AACCEE"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvSettingsSleep"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="22:30"
            android:textSize="36sp"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-thin"
            android:gravity="center"
            android:background="@drawable/bg_time_box"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WAKE TIME"
            android:textSize="11sp"
            android:textColor="#66AACCEE"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvSettingsWake"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="07:00"
            android:textSize="36sp"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-thin"
            android:gravity="center"
            android:background="@drawable/bg_time_box"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="40dp" />

        <TextView
            android:id="@+id/tvSettingsDone"
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            android:text="Done"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/pill_soft"
            android:paddingTop="13dp"
            android:paddingBottom="13dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</FrameLayout>
