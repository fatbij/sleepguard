<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_sleep"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

        <!-- Moon icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌙"
            android:textSize="64sp"
            android:layout_marginBottom="8dp" />

        <!-- App name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SleepGuard"
            android:textSize="28sp"
            android:textColor="#DDEEFF"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.05"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set your sleep window"
            android:textSize="13sp"
            android:textColor="#55AACCEE"
            android:letterSpacing="0.05"
            android:layout_marginBottom="48dp" />

        <!-- Bedtime label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BEDTIME"
            android:textSize="11sp"
            android:textColor="#66AACCEE"
            android:letterSpacing="0.15"
            android:layout_marginBottom="10dp" />

        <!-- Bedtime display box -->
        <TextView
            android:id="@+id/tvSleepTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="22:30"
            android:textSize="52sp"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-thin"
            android:gravity="center"
            android:background="@drawable/bg_time_box"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="32dp" />

        <!-- Wake time label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WAKE TIME"
            android:textSize="11sp"
            android:textColor="#66AACCEE"
            android:letterSpacing="0.15"
            android:layout_marginBottom="10dp" />

        <!-- Wake time display box -->
        <TextView
            android:id="@+id/tvWakeTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="07:00"
            android:textSize="52sp"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-thin"
            android:gravity="center"
            android:background="@drawable/bg_time_box"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="48dp" />

        <!-- Activate button -->
        <TextView
            android:id="@+id/btnActivate"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:text="Activate SleepGuard"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/pill_soft"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="16dp" />

        <!-- Stop button -->
        <TextView
            android:id="@+id/btnStop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stop SleepGuard"
            android:textSize="13sp"
            android:textColor="#44FFFFFF"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
